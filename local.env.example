# =============================================================================
# ocr-kb  ·  Configuration template
# =============================================================================
# Copy this file to local.env and uncomment / adjust the values for your setup.
# local.env is gitignored — it never gets committed.
#
# Jump to the section that matches your hardware:
#   → "PDF extraction profile"  to pick how PDFs are processed
#   → "Backend provider"        to switch between Ollama and LM Studio
#   → "VRAM limits"             if you hit out-of-memory errors
# =============================================================================

# ---------------------------------------------------------------------------
# Backend provider:  ollama  |  lmstudio
# ---------------------------------------------------------------------------
BACKEND_PROVIDER=ollama

# ---------------------------------------------------------------------------
# Pipeline mode
#   hybrid     — vision model for images/PDFs + text model for enrichment (default)
#   glm_only   — OCR extraction only, skip all text enrichment calls
#   gemma_only — text/Markdown files only; no vision model required
# ---------------------------------------------------------------------------
MODEL_BACKEND=hybrid

# ---------------------------------------------------------------------------
# Ollama settings  (used when BACKEND_PROVIDER=ollama)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_VISION_MODEL=llava:7b        # vision model for OCR / image extraction
OLLAMA_TEXT_MODEL=gemma3:4b         # text model for enrichment and RAG

# ---------------------------------------------------------------------------
# LM Studio settings  (used when BACKEND_PROVIDER=lmstudio)
# ---------------------------------------------------------------------------
# Vision / OCR model
# GLM_OCR_BASE_URL=http://localhost:1234/v1
# GLM_OCR_API_KEY=lm-studio
# GLM_OCR_MODEL_NAME=gemma-4-it   # match the model name shown in LM Studio

# Text enrichment + RAG model
# GEMMA_BASE_URL=http://localhost:1235/v1
# GEMMA_API_KEY=lm-studio
# GEMMA_MODEL_NAME=gemma-4-it

# ---------------------------------------------------------------------------
# Enable automatic text enrichment pass on every ingested page
# (OCR cleanup, auto-tagging).  Costs extra inference time.
# ---------------------------------------------------------------------------
ENABLE_GEMMA_ENRICHMENT=false

# ---------------------------------------------------------------------------
# Knowledge base paths
# ---------------------------------------------------------------------------
KB_DIR=./kb_data
KB_DB_PATH=./kb_data/kb.db
MARKDOWN_DIR=./kb_data/markdown

# ---------------------------------------------------------------------------
# Image / PDF ingestion quality
# ---------------------------------------------------------------------------
IMAGE_DPI=150            # increase to 300 for small or dense text
MIN_IMAGE_DIM=800
MIN_PDF_IMAGE_DIM=1000

# Extract embedded images (figures, diagrams, charts) from PDF pages and
# describe them using the vision model.
EXTRACT_EMBEDDED_IMAGES=false    # granite-docling captures figures in its page pass
EMBEDDED_IMAGE_MIN_PIXELS=10000    # skip images smaller than ~100×100

# ---------------------------------------------------------------------------
# PDF extraction profile  ← pick ONE block and uncomment it
#
# The extraction stack; the first success wins per page:
#   1. pdftext        — reads the native PDF text layer instantly (no ML)
#   2. granite-docling — local VLM OCR (ibm-granite/granite-docling-258M, ~258M params)
#   3. marker-pdf     — layout-aware markdown via Surya neural models (5 models)
#   4. pymupdf4llm    — structured markdown from the native text layer
#   5. pypdfium2      — plain text fallback (always available)
# Scanned pages from any text path fall through to:
#   6. Surya OCR    — direct detection + recognition (2 models, no layout pipeline)
#   7. Vision model — Ollama/LM Studio OCR as a last resort
#
# ── Profile A: instant / CPU-only ───────────────────────────────────────────
# Best when: GPU is fully occupied by Ollama, or you have no GPU.
# Quality:   good for clean digital PDFs; no layout intelligence for complex layouts.
# Speed:     instant (pdftext has no model load).
#
# USE_PDFTEXT=true
# USE_DOCLING=false
# USE_MARKER_PDF=false
# USE_SURYA_OCR=false
# USE_PYMUPDF4LLM=true
# MARKER_DEVICE=cpu
#
# ── Profile B: granite-docling / GPU (recommended when Ollama is not running) ─
# Best when: you want VLM-quality OCR for both digital and scanned PDFs.
# Quality:   excellent — granite-docling is a purpose-built document VLM.
# Speed:     first call downloads weights (~258M params); fast on GPU thereafter.
# Note:      uses ~2-3 GB VRAM. Disable when running Ollama with large models.
#
# USE_PDFTEXT=true
# USE_DOCLING=true
# DOCLING_DEVICE=cuda
# USE_MARKER_PDF=false
# USE_SURYA_OCR=false
# USE_PYMUPDF4LLM=false
# MARKER_DEVICE=cpu
#
# ── Profile C: high-quality / shared GPU (marker-pdf on CPU) ────────────────
# Best when: Ollama is running on the GPU and you want structured markdown output.
# Quality:   best — marker gives correct column order, tables, headings.
# Speed:     first PDF is slow (model load ~30-60 s on CPU); fast thereafter.
# Note:      marker runs on CPU so it doesn't compete with Ollama for VRAM.
#
# USE_PDFTEXT=false
# USE_DOCLING=false
# USE_MARKER_PDF=true
# USE_SURYA_OCR=true
# USE_PYMUPDF4LLM=false
# MARKER_DEVICE=cpu
#
# ── Profile D: high-quality / dedicated GPU ─────────────────────────────────
# Best when: Ollama is NOT running, or you have spare VRAM (>= 4 GB free).
# Quality:   best — same as C but GPU-accelerated.
# Speed:     first PDF ~10-15 s (GPU model load); fast thereafter.
# Caution:   will OOM if Ollama models are loaded at the same time.
#
# USE_PDFTEXT=false
# USE_DOCLING=false
# USE_MARKER_PDF=true
# USE_SURYA_OCR=true
# USE_PYMUPDF4LLM=false
# MARKER_DEVICE=cuda
#
# ── Default (granite-docling on CUDA) ───────────────────────────────────────
PREFER_PDF_TEXT=true
USE_PDFTEXT=false
USE_DOCLING=true
DOCLING_DEVICE=cuda
USE_MARKER_PDF=false
USE_SURYA_OCR=false
USE_PYMUPDF4LLM=false
MARKER_DEVICE=cpu

# ---------------------------------------------------------------------------
# Sub-page chunking  (improves retrieval precision on long pages)
# ---------------------------------------------------------------------------
# 0 = disabled (one DB entry per page).
# Set to e.g. 1200 to split each page into ~1200-char chunks at paragraph
# boundaries.  Increases index size proportionally.
CHUNK_SIZE=0
CHUNK_OVERLAP=100

# ---------------------------------------------------------------------------
# Embeddings
# ---------------------------------------------------------------------------
ENABLE_EMBEDDINGS=true

# SPECTER2 (default) — purpose-built for academic paper retrieval.
# Uses asymmetric document vs query embeddings for better precision.
# Requires: pip install 'ocr-kb[specter2]'  i.e.  pip install adapters
# Falls back automatically to all-MiniLM-L6-v2 if adapters is not installed.
EMBEDDING_MODEL=specter2

# Alternatives:
# sentence-transformers model (HuggingFace, auto-cached):
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# OR an Ollama-served embedding model (name:tag format auto-detected):
# EMBEDDING_MODEL=qwen3-embedding:0.6b

# ---------------------------------------------------------------------------
# Metadata extraction  (bibliographic info from first page of academic PDFs)
# ---------------------------------------------------------------------------
# Tries Crossref API (DOI-based, free, no key needed) then LLM fallback.
ENABLE_METADATA_EXTRACTION=true

# ---------------------------------------------------------------------------
# File watcher
# ---------------------------------------------------------------------------
WATCH_DIR=./data/inputs
WATCH_INTERVAL=5

# ---------------------------------------------------------------------------
# VRAM-safe inference limits
# Defaults are calibrated for an RTX 4070 12 GB running a 9B vision model
# (4-bit, ~5-6 GB) and a 4B text model (4-bit, ~2-3 GB) simultaneously.
# Raise MAX_IMAGE_PIXELS if you have headroom; lower it first on OOM.
# ---------------------------------------------------------------------------
MAX_IMAGE_PIXELS=1310720      # 1280×1024 hard cap before sending to vision model
MODEL_MAX_NEW_TOKENS=2048     # cap on generation length for both backends
RAG_CHUNK_CHARS=600           # chars per retrieved document snippet in 'ask'

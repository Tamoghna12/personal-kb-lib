# =============================================================================
# ocr-kb  ·  Model backend configuration
# =============================================================================
# Copy this file to local.env and adjust the values for your setup.
#
# ── QUICK START with Ollama (recommended) ────────────────────────────────────
# 1. Install Ollama: https://ollama.com
# 2. Pull models:
#      ollama pull llava:7b          # vision / OCR  (RTX 4070 comfortable)
#      ollama pull gemma3:4b         # text / RAG
#    For higher accuracy (needs more VRAM):
#      ollama pull qwen2.5vl:7b      # better vision
#      ollama pull llama3.2:3b       # fast text
# 3. Set BACKEND_PROVIDER=ollama below and adjust model names.
#
# ── LM Studio alternative ────────────────────────────────────────────────────
# LM Studio → Settings → Local Server → enable multi-model mode.
#   Port 1234  →  Vision/OCR model  (GLM-4V, LLaVA, or Gemma 4 multimodal)
#   Port 1235  →  Text model        (Gemma 4, Qwen, Mistral …)
# =============================================================================

# ---------------------------------------------------------------------------
# Backend provider:  ollama  |  lmstudio
# ---------------------------------------------------------------------------
BACKEND_PROVIDER=ollama

# ---------------------------------------------------------------------------
# Pipeline mode:
#   hybrid    — vision model for images/PDFs + text model for enrichment (default)
#   glm_only  — OCR extraction only, skip all text enrichment calls
#   gemma_only— Text/Markdown files only; no vision model required
# ---------------------------------------------------------------------------
MODEL_BACKEND=hybrid

# ---------------------------------------------------------------------------
# Ollama settings  (used when BACKEND_PROVIDER=ollama)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_VISION_MODEL=llava:7b       # vision model for OCR / image extraction
OLLAMA_TEXT_MODEL=gemma3:4b        # text model for enrichment and RAG

# ---------------------------------------------------------------------------
# LM Studio settings  (used when BACKEND_PROVIDER=lmstudio)
# ---------------------------------------------------------------------------
# Vision / OCR model  (port 1234 or 1235)
GLM_OCR_BASE_URL=http://localhost:1234/v1
GLM_OCR_API_KEY=lm-studio
GLM_OCR_MODEL_NAME=gemma-4-it   # match the model name shown in LM Studio

# Text enrichment + RAG model  (port 1235 in multi-model mode)
GEMMA_BASE_URL=http://localhost:1235/v1
GEMMA_API_KEY=lm-studio
GEMMA_MODEL_NAME=gemma-4-it

# Enable automatic text enrichment pass on every ingested page
# (OCR cleanup, auto-tagging).  Costs extra inference time.
ENABLE_GEMMA_ENRICHMENT=false

# ---------------------------------------------------------------------------
# Knowledge base paths
# ---------------------------------------------------------------------------
KB_DIR=./kb_data
KB_DB_PATH=./kb_data/kb.db
MARKDOWN_DIR=./kb_data/markdown   # flat Markdown mirror of every KB entry

# ---------------------------------------------------------------------------
# Image / PDF ingestion quality
# ---------------------------------------------------------------------------
IMAGE_DPI=150          # increase to 300 for small/dense text
MIN_IMAGE_DIM=800
MIN_PDF_IMAGE_DIM=1000

# Extract embedded images (figures, diagrams, charts) from PDF pages and
# describe them using the vision model. Descriptions are appended to the
# page text, making figures searchable and usable in RAG.
EXTRACT_EMBEDDED_IMAGES=true
EMBEDDED_IMAGE_MIN_PIXELS=10000  # skip images smaller than ~100×100

# Try to extract the native text layer from PDFs before falling back to the
# vision model.  Digital PDFs (e.g. exported from Word) will be processed
# instantly and without GPU inference.  Scanned PDFs fall back to OCR.
PREFER_PDF_TEXT=true

# ---------------------------------------------------------------------------
# Sub-page chunking  (improves retrieval precision on long pages)
# ---------------------------------------------------------------------------
# 0 = disabled (one DB entry per page, original behaviour).
# Set to e.g. 1200 to split each page at paragraph boundaries into ~1200-char
# chunks stored as separate entries.  Increases index size proportionally.
CHUNK_SIZE=0
CHUNK_OVERLAP=100   # overlap chars kept from the previous chunk for context

# ---------------------------------------------------------------------------
# Embeddings  (optional semantic search — needs sentence-transformers)
# ---------------------------------------------------------------------------
# pip install sentence-transformers   (or add it to optional deps)
ENABLE_EMBEDDINGS=false
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---------------------------------------------------------------------------
# File watcher
# ---------------------------------------------------------------------------
WATCH_DIR=./data/inputs
WATCH_INTERVAL=5

# ---------------------------------------------------------------------------
# VRAM-safe inference limits
# Defaults are calibrated for RTX 4070 12 GB with a 9B vision model (4-bit,
# ~5-6 GB) and a 4B text model (4-bit, ~2-3 GB) loaded simultaneously.
# Raise MAX_IMAGE_PIXELS if you have headroom; lower it first if you see OOM.
# ---------------------------------------------------------------------------
MAX_IMAGE_PIXELS=1310720      # 1280×1024 hard cap before sending to vision model
MODEL_MAX_NEW_TOKENS=2048     # cap on generation length for both backends
RAG_CHUNK_CHARS=600           # chars per retrieved document snippet in 'ask'
